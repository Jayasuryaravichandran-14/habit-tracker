{
  "rules": {
    "habittrack-users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "habittrack": {
      "$hash": {
        ".read": false,
        ".write": false
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
