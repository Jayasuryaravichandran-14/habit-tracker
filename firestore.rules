rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
      match /routineGroups/{groupId} { allow read, write: if isOwner(uid); }
      match /habits/{habitId}        { allow read, write: if isOwner(uid); }
      match /habitLogs/{logId}       { allow read, write: if isOwner(uid); }
      match /dailyLogs/{logId}       { allow read, write: if isOwner(uid); }
      match /logTrackers/{trackerId} { allow read, write: if isOwner(uid); }
      match /workoutTemplate/{day}   { allow read, write: if isOwner(uid); }
      match /workoutOverrides/{date} { allow read, write: if isOwner(uid); }
      match /workoutLogs/{date}      { allow read, write: if isOwner(uid); }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
